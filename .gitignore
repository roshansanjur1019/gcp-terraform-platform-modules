# Local Terraform directories and caches
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock info files
.terraform.tfstate.lock.info

# Terraform plan files
*.tfplan
*.tfplan.*

# Crash logs
crash.log
crash.*.log

# Override files (local-only customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# Local tooling binaries
.bin/

# NOTE: .terraform.lock.hcl is intentionally tracked so that provider
# selections are reproducible across machines and CI runs.
